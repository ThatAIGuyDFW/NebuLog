# Required
SENTINEL_INGEST_URL=https://sentinel-ingest.example.com:8001

# Optional — bearer token from Azure AD client-credentials flow
SENTINEL_API_TOKEN=

# TLS verification (set to false only in dev with a self-signed cert)
SENTINEL_VERIFY_TLS=true

# Collection mode: "journald" (default) or "syslog"
SENTINEL_MODE=journald

# Journald units to monitor (comma-separated; empty = all units)
SENTINEL_UNITS=sshd,sudo,cron,kernel

# Syslog file path (only used when SENTINEL_MODE=syslog)
SENTINEL_SYSLOG_PATH=/var/log/syslog

# Events per HTTP batch
SENTINEL_BATCH_SIZE=200

# Seconds between polls
SENTINEL_POLL_INTERVAL=5

# Directory for cursor / offset checkpoint files
SENTINEL_CHECKPOINT_DIR=/var/lib/sentinel

# Override source IP sent in X-Source-IP header (defaults to auto-detect)
SENTINEL_SOURCE_IP=

# Retry settings
SENTINEL_MAX_RETRIES=5
SENTINEL_RETRY_WAIT=2
