# Required
SENTINEL_INGEST_URL=https://sentinel-ingest.example.com:8001

# Optional — bearer token from Azure AD client-credentials flow
SENTINEL_API_TOKEN=

# TLS verification (set to false only in dev with a self-signed cert)
SENTINEL_VERIFY_TLS=true

# Channels to collect (comma-separated)
SENTINEL_CHANNELS=Security,System,Application

# Events per HTTP batch
SENTINEL_BATCH_SIZE=200

# Seconds between polls per channel
SENTINEL_POLL_INTERVAL=5

# Directory where per-channel checkpoint files are written
SENTINEL_CHECKPOINT_DIR=C:\ProgramData\Sentinel\checkpoints

# Override source IP sent in X-Source-IP header (defaults to local IP auto-detect)
SENTINEL_SOURCE_IP=

# Retry settings
SENTINEL_MAX_RETRIES=5
SENTINEL_RETRY_WAIT=2
